{
  "expo": {
    "name": "MomDontLose",
    "slug": "mom-dont-lose",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/appico.png",
    "scheme": "momdontlose",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.momdontlose.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/appico.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ce02f784-47b0-44c9-88cc-018ac948ff22"
      }
    }
  }
}
